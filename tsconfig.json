{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "target": "ESNext",
    "lib": [
      "ESNext",
      "DOM"
    ],
    "jsx": "react-native",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@/constants": [
        "./constants/index.ts"
      ],
      "@/constants/*": [
        "./constants/*"
      ],
      "@/components": [
        "./components/index.ts"
      ],
      "@/components/*": [
        "./components/*"
      ],
      "@/hooks": [
        "./hooks/index.ts"
      ],
      "@/hooks/*": [
        "./hooks/*"
      ],
      "@/services": [
        "./services/index.ts"
      ],
      "@/services/*": [
        "./services/*"
      ],
      "@/store": [
        "./store/index.ts"
      ],
      "@/store/*": [
        "./store/*"
      ],
      "@/utils": [
        "./utils/index.ts"
      ],
      "@/utils/*": [
        "./utils/*"
      ],
      "@/assets/*": [
        "./assets/*"
      ],
      "@/types/*": [
        "./types/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.d.ts",
    "expo-env.d.ts",
    ".expo/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "babel.config.js",
    "metro.config.js"
  ]
}
